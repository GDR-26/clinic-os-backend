# ============================================================
# SMILE DENTAL BACKEND — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git — add it to .gitignore
# ============================================================

# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────
# SUPABASE
# Get these from: supabase.com → your project → settings → API
# ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────
# JWT (JSON Web Token)
# Why JWT? It lets us verify user identity without hitting DB on every request
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long
JWT_EXPIRES_IN=12h

# ─────────────────────────────────────────
# REFRESH TOKENS
# Why refresh tokens? JWT expires in 12h, refresh token lets user stay logged in
# without re-entering password (up to 30 days)
# ─────────────────────────────────────────
REFRESH_TOKEN_SECRET=your-refresh-token-secret-different-from-jwt-secret
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─────────────────────────────────────────
# EMAIL (for password reset, notifications)
# Using Gmail: enable "App Passwords" in Google Account settings
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=Smile Dental <your-email@gmail.com>

# ─────────────────────────────────────────
# n8n WEBHOOK PROXY
# Why proxy? Hides real n8n URLs and API keys from frontend
# Frontend calls our backend → backend calls n8n
# ─────────────────────────────────────────
N8N_BASE_URL=https://n8n-production-1b36.up.railway.app/webhook
N8N_MASTER_API_KEY=SMILE-DENTAL-2026-SECRET

# ─────────────────────────────────────────
# FRONTEND URL (for CORS)
# Only this domain can call our backend API
# ─────────────────────────────────────────
FRONTEND_URL=https://smile-appointment.pages.dev

# ─────────────────────────────────────────
# SUPER ADMIN (platform-level, hidden from clinics)
# Created on first server start if not exists
# ─────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@smiledental.internal
SUPER_ADMIN_PASSWORD=change-this-immediately-on-first-login
